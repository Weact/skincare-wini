rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedInNonAnonymous() {
      return request.auth != null && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    // Friendship is symmetric by construction (accepting a request always
    // writes both users/{A}/friends/{B} and users/{B}/friends/{A} together),
    // so checking the owner's own friends subcollection for the requester's
    // uid is enough — no separate "friendship" document needed.
    function isFriend(userId) {
      return exists(/databases/$(database)/documents/users/$(userId)/friends/$(request.auth.uid));
    }

    // Per-tracker visibility on top of friendship — `trackerVisibility` is a
    // map like { skincare: true, workout: false, poop: true }. Missing map
    // or missing key both default to visible, so accounts that never touch
    // this setting keep today's behaviour (everything visible to friends).
    function trackerVisible(userId, tracker) {
      let owner = get(/databases/$(database)/documents/users/$(userId)).data;
      return owner.get('trackerVisibility', {}).get(tracker, true) == true;
    }

    // True if there's a still-pending request from `userId` to `friendUid` —
    // the condition that justifies `friendUid` writing themselves into
    // `userId`'s friend list as part of accepting it.
    function hasPendingRequest(userId, friendUid) {
      let req = get(/databases/$(database)/documents/friendRequests/$(userId + '_' + friendUid)).data;
      return req.from == userId && req.to == friendUid && req.status == 'pending';
    }

    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Friend-only read-only access to a user's trackers. The owner-only rule
    // above still applies independently; Firestore grants access if either
    // rule allows it.
    match /users/{userId}/workouts/{workoutId} {
      allow read: if isSignedInNonAnonymous() && isFriend(userId) && trackerVisible(userId, 'workout');
    }

    match /users/{userId}/poops/{poopId} {
      allow read: if isSignedInNonAnonymous() && isFriend(userId) && trackerVisible(userId, 'poop');
    }

    match /users/{userId}/steps/{stepId} {
      allow read: if isSignedInNonAnonymous() && isFriend(userId) && trackerVisible(userId, 'workout');
    }

    match /users/{userId}/categories/{categoryId} {
      allow read: if isSignedInNonAnonymous() && isFriend(userId) && trackerVisible(userId, 'skincare');
    }

    match /users/{userId}/types/{typeId} {
      allow read: if isSignedInNonAnonymous() && isFriend(userId) && trackerVisible(userId, 'skincare');
    }

    match /users/{userId}/products/{productId} {
      allow read: if isSignedInNonAnonymous() && isFriend(userId) && trackerVisible(userId, 'skincare');
    }

    // Lets a friend read the owner's profile doc directly (for the shared
    // profile page's header), without needing anything beyond friendship.
    match /users/{userId} {
      allow read: if isSignedInNonAnonymous() && isFriend(userId);
    }

    // Each user's own friend list — { [friendUid]: { code, alias, since } }.
    // Reading/editing/removing your own entries is covered by the owner
    // rule above. The two extra grants here exist only to make *accepting* a
    // request work without a server: the acceptor (friendUid) needs to write
    // themselves into the sender's (userId's) list too, and either side
    // needs to be able to remove themselves from the other's list to
    // unfriend instantly without requiring the other person to also act.
    match /users/{userId}/friends/{friendUid} {
      allow create: if isSignedInNonAnonymous() && request.auth.uid == friendUid
        && hasPendingRequest(userId, friendUid);
      allow delete: if request.auth != null && request.auth.uid == friendUid;
    }

    // Friend requests, doc id "{fromUid}_{toUid}" — lets either side query
    // just their half (where('to'/'from', '==', myUid)) without needing a
    // broader rule Firestore can't validate against a list query.
    match /friendRequests/{requestId} {
      allow read: if request.auth != null
        && (request.auth.uid == resource.data.from || request.auth.uid == resource.data.to);
      allow create: if isSignedInNonAnonymous()
        && request.auth.uid == request.resource.data.from
        && request.resource.data.to != request.auth.uid
        && request.resource.data.status == 'pending'
        && requestId == request.resource.data.from + '_' + request.resource.data.to
        && get(/databases/$(database)/documents/users/$(request.resource.data.to)).data.get('profileVisibility', 'private') == 'public';
      allow delete: if request.auth != null
        && (request.auth.uid == resource.data.from || request.auth.uid == resource.data.to);
    }

    // code -> uid lookup for resolving a friend code, both to send a
    // request and to display a friend's code before an alias is set.
    match /profileCodes/{code} {
      allow read: if isSignedInNonAnonymous();
      allow create: if isSignedInNonAnonymous() && request.resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }
  }
}
