rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedInNonAnonymous() {
      return request.auth != null && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    // True if `userId` currently shares their Workouts/Poop data with the
    // requester — either Public (any signed-in, non-anonymous account) or
    // Whitelist (the requester's uid is explicitly listed on the owner's
    // profile). Private falls through to false.
    function ownerSharesWith(userId) {
      let owner = get(/databases/$(database)/documents/users/$(userId)).data;
      return owner.profileVisibility == 'public'
        || (owner.profileVisibility == 'whitelist' && request.auth.uid in owner.get('allowedViewerUids', []));
    }

    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Public/whitelist read-only access to a user's workouts + poops. The
    // owner-only rule above still applies independently; Firestore grants
    // access if either rule allows it.
    match /users/{userId}/workouts/{workoutId} {
      allow read: if isSignedInNonAnonymous() && ownerSharesWith(userId);
    }

    match /users/{userId}/poops/{poopId} {
      allow read: if isSignedInNonAnonymous() && ownerSharesWith(userId);
    }

    // Lets a viewer read the owner's profile doc directly (for the
    // shared-profile page itself), without needing the owner's own uid
    match /users/{userId} {
      allow read: if isSignedInNonAnonymous() && ownerSharesWith(userId);
    }

    // code -> uid lookup for resolving a share code to its owner
    match /profileCodes/{code} {
      allow read: if isSignedInNonAnonymous();
      allow create: if isSignedInNonAnonymous() && request.resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    // Same shape as profileCodes, but resolves a person's own "viewer code"
    // to their uid — this is what gets typed into someone else's whitelist,
    // instead of their raw Firebase uid
    match /viewerCodes/{code} {
      allow read: if isSignedInNonAnonymous();
      allow create: if isSignedInNonAnonymous() && request.resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }
  }
}
